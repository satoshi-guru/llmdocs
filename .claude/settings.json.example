{
  "env": {
    "LLMDOCS_DIR": "/path/to/llmdocs",
    "LLMDOCS_HOME": "~/.llmdocs"
  },
  "permissions": {
    "allow": [
      "WebFetch(https://*)",
      "WebSearch",
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(gh:*)"
    ]
  }
}
